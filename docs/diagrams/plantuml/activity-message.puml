@startuml 活动图_消息沟通
skinparam backgroundColor #FEFEFE

title WebSocket消息沟通活动图

|#LightBlue|用户A|
|#LightGreen|SocketIO服务器|
|#LightYellow|数据库|
|#LightCoral|用户B|

|用户A|
start
:进入消息中心;
:WebSocket connect;

|SocketIO服务器|
:验证Session登录状态;
:join_room('user_A');
if (角色=admin?) then (是)
  :join_room('admin');
endif
:emit 'connected';

|用户B|
:进入消息中心;
:WebSocket connect;
:join_room('user_B');

|用户A|
:输入消息内容;
:点击发送;

|SocketIO服务器|
:接收send_message事件;
:校验消息内容（非空、长度<=500）;
:校验房间名白名单;

|数据库|
:INSERT messages;

|SocketIO服务器|
:emit 'new_message' to room;

|用户B|
:实时接收消息;
:显示未读标记;

|用户B|
:打开对话窗口;

|数据库|
:UPDATE messages SET status='read'
WHERE receiver_id=B AND sender_id=A;

|用户B|
:回复消息;

|SocketIO服务器|
:持久化到数据库;
:广播给用户A;

|用户A|
:实时接收回复;

stop
@enduml