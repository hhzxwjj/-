@startuml 用例图
skinparam packageStyle rectangle
skinparam actorStyle awesome

left to right direction

actor "家长/学员" as Parent
actor "管理员" as Admin
actor "访客" as Visitor

rectangle "书法报名管理系统" {
    usecase "UC01: 用户注册" as UC01
    usecase "UC02: 用户登录" as UC02
    usecase "UC03: 完善个人信息" as UC03
    usecase "UC04: 浏览课程" as UC04
    usecase "UC05: 查看课程详情" as UC05
    usecase "UC06: 在线报名" as UC06
    usecase "UC07: 模拟缴费" as UC07
    usecase "UC08: 查看报名记录" as UC08
    usecase "UC09: 消息沟通" as UC09
    usecase "UC10: 修改密码" as UC10
    
    usecase "UC11: 发布课程" as UC11
    usecase "UC12: 管理学生" as UC12
    usecase "UC13: 签到打卡" as UC13
    usecase "UC14: 课时统计" as UC14
    usecase "UC15: 临时调课" as UC15
    usecase "UC16: 人员调整" as UC16
}

' 家长关系
Parent --> UC01
Parent --> UC02
Parent --> UC03
Parent --> UC04
Parent --> UC05
Parent --> UC06
Parent --> UC07
Parent --> UC08
Parent --> UC09
Parent --> UC10

' 管理员关系
Admin --> UC02
Admin --> UC04
Admin --> UC05
Admin --> UC09
Admin --> UC11
Admin --> UC12
Admin --> UC13
Admin --> UC14
Admin --> UC15
Admin --> UC16

' 访客关系
Visitor --> UC01
Visitor --> UC02

' 包含关系
UC06 ..> UC03 : <<include>>
UC06 ..> UC07 : <<include>>
UC16 ..> UC12 : <<include>>

' 扩展关系
UC05 <.. UC08 : <<extend>>
UC13 <.. UC14 : <<extend>>

note right of UC06
  前置条件：
  1. 用户已登录
  2. 个人信息已完善
  3. 课程未满员
end note

note bottom of Admin
  管理员拥有全部权限，
  可管理课程、学生、
  签到和消息回复
end note

@enduml