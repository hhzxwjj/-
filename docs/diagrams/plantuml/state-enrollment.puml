@startuml 状态图_报名记录
skinparam backgroundColor #FEFEFE

title 报名记录生命周期状态图

[*] --> 待缴费 : 用户提交报名

state 待缴费 {
  [*] --> 校验中 : 系统处理
  校验中 --> 校验通过 : 余量充足
  校验中 --> 报名失败 : 余量不足/重复报名
}

待缴费 --> 已缴费 : 模拟支付成功
待缴费 --> 已取消 : 用户取消/超时

state 已缴费 {
  [*] --> 上课中 : 课程开始
  上课中 --> 正常出勤 : 签到 present
  上课中 --> 缺勤 : 签到 absent
  上课中 --> 请假 : 签到 leave
}

已缴费 --> 已结课 : 课程结束
已缴费 --> 调课中 : 管理员临时调课

state 调课中 {
  [*] --> 临时签到 : 添加临时记录
  临时签到 --> 已缴费 : 调课完成
}

已缴费 --> 已转出 : 管理员人员调整

state c <<choice>>
已结课 --> c

c --> [*] : 正常结束
c --> 已转出 : 管理员调整

state 已转出 {
  [*] --> 新课程待缴费 : 转入新课程
}

已转出 --> 已缴费 : 重新缴费
已取消 --> [*]
报名失败 --> [*]

note right of 已缴费
  核心状态：
  - attendance_count 自动统计
  - 支持历史签到修改
  - 课时不足时预警
end note

note right of 调课中
  临时调课不改变
  原课程的报名关系，
  仅增加签到记录
end note

@enduml